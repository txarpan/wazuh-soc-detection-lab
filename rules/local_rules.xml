<group name="ssh,bruteforce,">

  <!-- T1110.001: Brute force against non-existent users -->
  <rule id="100001" level="10" frequency="4" timeframe="60">
    <if_matched_sid>5710</if_matched_sid>
    <same_source_ip />
    <description>SSH Brute Force Attack Detected: Multiple failed attempts from $(srcip)</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
  </rule>

  <!-- T1110.001: Brute force against valid users (root, vboxuser etc) -->
  <rule id="100002" level="10" frequency="4" timeframe="60">
    <if_matched_sid>5760</if_matched_sid>
    <same_source_ip />
    <description>SSH Brute Force Against Valid User: Multiple failed attempts from $(srcip)</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
  </rule>

  <!-- T1078: Account compromise after brute force -->
  <rule id="100003" level="14" timeframe="300">
    <if_matched_sid>100002</if_matched_sid>
    <same_source_ip />
    <description>CRITICAL: Successful login after Brute Force from $(srcip) - Possible Account Compromise</description>
    <mitre>
      <id>T1078</id>
    </mitre>
  </rule>


<!-- T1046: UFW Blocked Connection — base rule -->
  <rule id="100005" level="4">
    <program_name>kernel</program_name>
    <match>UFW BLOCK</match>
    <description>UFW blocked incoming connection from $(srcip)</description>
    <mitre>
      <id>T1046</id>
    </mitre>
  </rule>

  <!-- T1046: Port Scan Detection — multiple UFW blocks same IP -->
  <rule id="100004" level="10" frequency="20" timeframe="10">
    <if_matched_sid>100005</if_matched_sid>
    <description>Port Scan Detected: High volume of blocked connections</description>
    <mitre>
      <id>T1046</id>
    </mitre>
  </rule>

<!-- T1548.003: Sudo abuse — sensitive file access -->
  <rule id="100006" level="12">
    <if_sid>5402</if_sid>
    <match>COMMAND=/usr/bin/cat /etc/shadow</match>
    <description>CRITICAL: Sudo used to read /etc/shadow — Possible credential harvesting by $(dstuser)</description>
    <mitre>
      <id>T1548.003</id>
      <id>T1003.008</id>
    </mitre>
  </rule>

  <!-- T1548.003: Sudo abuse — privilege confirmation -->
  <rule id="100007" level="10">
    <if_sid>5402</if_sid>
    <match>COMMAND=/usr/bin/whoami</match>
    <description>Sudo used to confirm root privilege — Possible post-exploitation activity by $(dstuser)</description>
    <mitre>
      <id>T1548.003</id>
    </mitre>
  </rule>

  <!-- T1548.003: Sudo abuse — passwd file access -->
  <rule id="100008" level="10">
    <if_sid>5402</if_sid>
    <match>COMMAND=/usr/bin/cat /etc/passwd</match>
    <description>Sudo used to read /etc/passwd — Possible user enumeration by $(dstuser)</description>
    <mitre>
      <id>T1548.003</id>
    </mitre>
  </rule>

<!-- T1110.001: Windows Brute Force Detection -->
  <rule id="100009" level="10" frequency="5" timeframe="60">
    <if_matched_sid>60122</if_matched_sid>
    <same_field>win.eventdata.targetUserName</same_field>
    <description>Windows Brute Force Detected: Multiple failed logons for $(win.eventdata.targetUserName)</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
  </rule>

  <!-- T1078: Windows Successful Login After Brute Force -->
  <rule id="100010" level="14" timeframe="300">
    <if_matched_sid>100009</if_matched_sid>
    <same_field>win.eventdata.targetUserName</same_field>
    <description>CRITICAL: Successful Windows login after Brute Force — Possible Account Compromise</description>
    <mitre>
      <id>T1078</id>
    </mitre>
  </rule>


</group>
